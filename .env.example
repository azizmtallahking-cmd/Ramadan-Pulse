# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# For Vercel: Add this to your project's Environment Variables in the Vercel dashboard.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# For Vercel: Use your Vercel deployment URL (e.g., https://ramadan-pulse.vercel.app)
APP_URL="https://ramadan-pulse.vercel.app"

# Firebase Configuration (Optional if using firebase-applet-config.json)
# If you prefer environment variables, prefix them with VITE_ for client-side access.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
